{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "kw_packs": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "kw_groups": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "name": { "type": "string" },
                                "weight": { "type": "number", "minimum": 0 },
                                "colour": {
                                    "type": "array",
                                    "items": { "type": "integer", "minimum": 0, "maximum": 255 },
                                    "minItems": 3,
                                    "maxItems": 3
                                },
                                "words": {
                                    "type": "array",
                                    "items": { "type": "string" },
                                    "minItems": 1,
                                    "maxItems": 50
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}