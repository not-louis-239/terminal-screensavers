{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
        "$schema": { "type": "string" },
        "materials": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "name": {"type": "string"},
                    "flame_colour": {
                        "type": "array",
                        "items": { "type": "integer", "minimum": 0, "maximum": 255 }
                    },
                    "description": {"type": "string"}
                }
            }
        }
    }
}